{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main and pet windows",
  "windows": ["main", "pet"],
  "permissions": [
    "core:default",
    "opener:default",
    "autostart:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://api.notion.com/*" }]
    }
  ]
}
